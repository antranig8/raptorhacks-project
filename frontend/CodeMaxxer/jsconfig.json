{
    "compilerOptions": {
        "baseUrl": "./",
        "paths": {
            "@/*": [
                "src/*"
            ],
            "@": [
                "src"
            ],
            "@pages/*": [
                "src/pages/*"
            ],
            "@pages": [
                "src/pages"
            ],
            "@home/*": [
                "src/pages/Home/*"
            ],
            "@home": [
                "src/pages/Home"
            ],
            "@dashboard/*": [
                "src/pages/Dashboard/*"
            ],
            "@dashboard": [
                "src/pages/Dashboard"
            ]
        }
    },
    "include": [
        "src"
    ]
}