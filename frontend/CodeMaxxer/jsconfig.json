{
    "compilerOptions": {
        "baseUrl": "./",
        "paths": {
            "@/*": [
                "src/*"
            ],
            "@pages/*": [
                "src/pages/*"
            ],
            "@home/*": [
                "src/pages/Home/*"
            ],
            "@dashboard/*": [
                "src/pages/Dashboard/*"
            ],
            "@d_general/*": [
                "src/pages/Dashboard/components/general/*"
            ],
            "@d_study/*": [
                "src/pages/Dashboard/components/study/*"
            ],
            "@d_support/*": [
                "src/pages/Dashboard/components/support/*"
            ]
        }
    },
    "include": [
        "src"
    ]
}